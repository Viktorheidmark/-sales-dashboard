DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
OPENAI_API_KEY=sk-...
USE_AI_PLANNER=true
CHAT_INCLUDE_ANALYSIS_META=false
JWT_SECRET_KEY=replace-with-32-random-bytes-hex-e.g.-openssl-rand-hex-32

# Canonical analytics orchestration (backend/app/analytics/). Default off for safe rollback.
AI_ORCHESTRATED_ANALYTICS_ENABLED=false
# Developer-only: attach orchestration_trace to analysis_meta (never for end users).
ANALYTICS_DEBUG_TRACE=false
# Run new planner in parallel with legacy for diff logging only (no duplicate UI output).
ANALYTICS_SHADOW_EVAL=false
