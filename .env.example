DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
USE_AI_PLANNER=true
JWT_SECRET_KEY=replace-with-32-random-bytes-hex-e.g.-openssl-rand-hex-32

# ── Analytics orchestration ──────────────────────────────────────────────────
# Enable the canonical orchestrated analytics pipeline (backend/app/analytics/).
# Set this to true for the complete demo experience — it powers explicit period
# comparisons rendered as tenant-coloured comparison bar charts.
AI_ORCHESTRATED_ANALYTICS_ENABLED=true

# Developer-only diagnostics. MUST remain false for external users: when true it
# attaches an orchestration_trace to the response analysis_meta.
ANALYTICS_DEBUG_TRACE=false

# Internal analysis metadata in chat responses. MUST remain false for external
# users: keeps technical execution details out of the customer-facing payload.
CHAT_INCLUDE_ANALYSIS_META=false

# Run the new planner alongside the legacy path for diff logging only (no
# duplicate UI output). Safe to leave false.
ANALYTICS_SHADOW_EVAL=false
